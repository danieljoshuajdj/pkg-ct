{
  "name": "@danijsrr/pkg-ct",
  "version": "0.4.0",
  "description": "The AI-powered dependency intelligence and maintenance layer for Node.js projects.",
  "type": "module",
  "bin": {
    "pkg-ct": "dist/cli/index.js",
    "pkg-caretaker": "dist/cli/index.js",
    "node-modules-doctor": "dist/cli/index.js",
    "nmd": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    }
  },
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "CHANGELOG.md",
    "docs"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "doctor": "tsx src/cli/index.ts doctor"
  },
  "keywords": [
    "npm",
    "dependencies",
    "dependency-analysis",
    "doctor",
    "monorepo",
    "supply-chain",
    "cli",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@npmcli/arborist": "^8.0.0",
    "cac": "^6.7.14",
    "chalk": "^5.4.1",
    "execa": "^9.5.2",
    "fast-glob": "^3.3.3",
    "npm-package-arg": "^12.0.2",
    "ora": "^8.1.1",
    "pacote": "^21.0.0",
    "pkg-types": "^1.3.1",
    "semver": "^7.6.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@types/node": "^22.10.5",
    "@types/npm-package-arg": "^6.1.4",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danieljoshuajdj/pkg-ct.git"
  }
}
