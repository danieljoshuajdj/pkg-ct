{
  "name": "@danijsrr/pkg-ct",
  "version": "0.6.0",
  "description": "Dependency intelligence, health scoring, diagnostics, and package health analysis for Node.js, React, and TypeScript projects.",
  "type": "module",
  "bin": {
    "pkg-ct": "dist/cli/index.js",
    "pkg-caretaker": "dist/cli/index.js",
    "node-modules-doctor": "dist/cli/index.js",
    "nmd": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    }
  },
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "SUPPORT.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "docs",
    "V0_6_0_PRODUCTION_AUDIT.md"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "doctor": "tsx src/cli/index.ts doctor",
    "release-gate": "tsx scripts/release-gate.ts"
  },
  "keywords": [
    "dependency-analysis",
    "dependency-intelligence",
    "dependency-health",
    "dependency-management",
    "dependency-diagnostics",
    "dependency-scanner",
    "package-health",
    "nodejs",
    "nodejs-dependency-analysis",
    "react",
    "react-dependency-analysis",
    "typescript",
    "typescript-cli",
    "npm",
    "dependency-graph",
    "supply-chain-security",
    "cli",
    "devtools",
    "monorepo"
  ],
  "author": "Daniel Joshua",
  "license": "MIT",
  "homepage": "https://github.com/danieljoshuajdj/danijsrr-pkg-ct#readme",
  "bugs": {
    "url": "https://github.com/danieljoshuajdj/danijsrr-pkg-ct/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/danieljoshuajdj"
  },
  "dependencies": {
    "@npmcli/arborist": "^8.0.0",
    "cac": "^6.7.14",
    "chalk": "^5.4.1",
    "execa": "^9.5.2",
    "fast-glob": "^3.3.3",
    "npm-package-arg": "^12.0.2",
    "ora": "^8.1.1",
    "pacote": "^21.0.0",
    "pkg-types": "^1.3.1",
    "semver": "^7.6.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@types/node": "^22.10.5",
    "@types/npm-package-arg": "^6.1.4",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danieljoshuajdj/danijsrr-pkg-ct.git"
  }
}
